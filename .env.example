# ═══════════════════════════════════════════════════════════════════════
# Personal Brand Equity Calculator — Environment Variables
# Copy this file to .env.local for local development (never commit .env)
# Set these as Environment Variables in Vercel Dashboard → Settings → Env
# ═══════════════════════════════════════════════════════════════════════

# ── SUPABASE (required for cloud storage + auth) ─────────────────────
# Find these at: https://supabase.com/dashboard → your project → Settings → API
SUPA_URL=https://your-project-id.supabase.co
SUPA_SERVICE_KEY=eyJhbGc...   # service_role key — NEVER expose to frontend

# ── ADMIN ────────────────────────────────────────────────────────────
# Secret for the /api/admin-data endpoint. Change this before going live.
ADMIN_SECRET=pbes2025admin

# ── YOUTUBE DATA API v3 (required for real YouTube subscriber counts) ──
# Free: 10,000 units/day (~3,000 channel lookups). Create a key at:
# 1. https://console.cloud.google.com → New Project
# 2. APIs & Services → Library → search "YouTube Data API v3" → Enable
# 3. APIs & Services → Credentials → Create Credentials → API key
# Without this key the scraper falls back to HTML parsing (less reliable).
YOUTUBE_API_KEY=AIzaSy...

# ── OPTIONAL: GitHub API (raises scraping rate limit 60→5000 req/hr) ─
# Create at: https://github.com/settings/tokens (no permissions needed)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
